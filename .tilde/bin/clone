#!/usr/bin/env zsh
# shellcheck shell=bash

# shellcheck source=../lib/zsh/logging.zsh
source "${ZSH_LIB}/logging.zsh"

readonly REPO="$1${2:+/$2}"
readonly DEST="${SRC}/${REPO}"

[[ "$#" -gt 1 ]] || usage "clone <repo_owner> <repo_name>"

[[ -e "${DEST}" ]] ||
  git clone "git@github.com:${REPO}.git" "${DEST}" >/dev/null

#!/usr/bin/env python3
"""Write preferences from a JSON file via `defaults write`.

Reads a preferences.json containing a label and an array of domain
entries, then writes each typed default to the corresponding domain.

Expected JSON format:

    {
        "label": "App Name",
        "preferences": [
            {
                "domain": "com.example.app",
                "defaults": {
                    "key": { "bool": true },
                    "key": { "int": 0 },
                    "key": { "float": 1.5 },
                    "key": { "string": "value" }
                },
                "currentHostDefaults": { ... },
                "shortcuts": {
                    "action": { "keyCode": 49, "modifierFlags": 786432 }
                }
            }
        ]
    }

String values beginning with ~ are expanded to $HOME.
Shortcut entries are written as plist dict literals.
"""

from __future__ import annotations

import json
import os
import subprocess
import sys
from typing import Any


def _run(cmd: list[str], *, check: bool = True) -> None:
    subprocess.run(cmd, check=check, capture_output=True, text=True)


def _die(msg: str) -> None:
    print(msg, file=sys.stderr)
    sys.exit(3)


def _resolve_value(typed: dict[str, Any]) -> tuple[str, str] | None:
    """Return the defaults flag and string value for a typed entry."""
    if "bool" in typed:
        return "-bool", "true" if typed["bool"] else "false"
    if "int" in typed:
        return "-int", str(typed["int"])
    if "float" in typed:
        return "-float", str(typed["float"])
    if "double" in typed:
        return "-float", str(typed["double"])
    if "string" in typed:
        return "-string", os.path.expanduser(typed["string"])
    return None


def _write_defaults(
    domain: str,
    defaults: dict[str, Any],
    *,
    current_host: bool = False,
) -> None:
    """Write typed defaults to a domain."""
    base = ["defaults"]
    if current_host:
        base.append("-currentHost")
    base.append("write")

    for key, typed in defaults.items():
        if not typed:
            continue
        resolved = _resolve_value(typed)
        if resolved is None:
            continue
        flag, value = resolved
        _run([*base, domain, key, flag, value])


def _write_shortcuts(
    domain: str,
    shortcuts: dict[str, dict[str, int]],
) -> None:
    """Write keyboard shortcuts as plist dict literals."""
    for key, fields in shortcuts.items():
        plist = "".join(
            f"<key>{k}</key><integer>{v}</integer>"
            for k, v in fields.items()
        )
        _run([
            "defaults", "write", domain, key,
            f"<dict>{plist}</dict>",
        ])


def main() -> None:
    """Entry point."""
    if len(sys.argv) < 2:
        print("Usage: setprefs <preferences.json>", file=sys.stderr)
        sys.exit(9)

    path = sys.argv[1]
    if not os.path.isfile(path):
        _die(f"{path} does not exist.")

    with open(path) as f:
        config = json.load(f)

    label = config.get("label", path)
    print(f"Writing preferences for {label}...")

    for entry in config.get("preferences", []):
        domain = entry["domain"]
        _write_defaults(domain, entry.get("defaults", {}))
        _write_defaults(
            domain,
            entry.get("currentHostDefaults", {}),
            current_host=True,
        )
        _write_shortcuts(domain, entry.get("shortcuts", {}))

    print(f"Preferences applied for {label}.")


if __name__ == "__main__":
    main()

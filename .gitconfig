    name = maximlevey
    email = 72744507+maximlevey@users.noreply.github.com

[core]
    autocrlf = input
    editor = cursor --wait
    excludesfile = ~/.gitignore.global

[init]
    defaultBranch = main

[pull]
    rebase = false

[fetch]
    prune = true

[rerere]
    enabled = true

[color]
    ui = auto